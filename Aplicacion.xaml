<!-- Descripcion: Recursos globales de la aplicacion WPF. -->
<Application x:Class="LanzadorScripts.Aplicacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="VentanaPrincipal.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0B1220" />
        <SolidColorBrush x:Key="PanelBrush" Color="#111827" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#172033" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#334155" />
        <SolidColorBrush x:Key="AccentBrush" Color="#38BDF8" />
        <SolidColorBrush x:Key="TextBrush" Color="#E5E7EB" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8" />
        <SolidColorBrush x:Key="InputBrush" Color="#0F172A" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="#1E293B" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource PanelAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
    </Application.Resources>
</Application>
