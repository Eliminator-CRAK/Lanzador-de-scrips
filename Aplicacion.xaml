<!-- Descripcion: Recursos globales de la aplicacion WPF. -->
<Application x:Class="LanzadorScripts.Aplicacion"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="VentanaPrincipal.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#0F1115" />
        <SolidColorBrush x:Key="PanelBrush" Color="#1A1C23" />
        <SolidColorBrush x:Key="PanelAltBrush" Color="#252831" />
        <SolidColorBrush x:Key="PanelSoftBrush" Color="#20232B" />
        <SolidColorBrush x:Key="InputBrush" Color="#111318" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#343844" />
        <SolidColorBrush x:Key="BorderBrushSubtle" Color="#242832" />
        <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="#1D2D50" />
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444" />
        <SolidColorBrush x:Key="DangerSoftBrush" Color="#3A1D24" />
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981" />
        <SolidColorBrush x:Key="SuccessSoftBrush" Color="#17342D" />
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B" />
        <SolidColorBrush x:Key="WarningSoftBrush" Color="#342916" />
        <SolidColorBrush x:Key="TextBrush" Color="#F3F4F6" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA3AF" />
        <SolidColorBrush x:Key="DimTextBrush" Color="#6B7280" />
        <SolidColorBrush x:Key="TerminalBrush" Color="#05070A" />
        <SolidColorBrush x:Key="TerminalTextBrush" Color="#D1FAE5" />

        <Geometry x:Key="IconoBuscar">M21,21 L16.65,16.65 M19,11 A8,8 0 1 1 3,11 A8,8 0 1 1 19,11</Geometry>
        <Geometry x:Key="IconoTerminal">M4,17 L10,11 L4,5 M12,19 L20,19</Geometry>
        <Geometry x:Key="IconoPlay">M6,4 L20,12 L6,20 Z</Geometry>
        <Geometry x:Key="IconoCuadrado">M6,6 L18,6 L18,18 L6,18 Z</Geometry>
        <Geometry x:Key="IconoCerrar">M18,6 L6,18 M6,6 L18,18</Geometry>
        <Geometry x:Key="IconoAjustes">M12,15.5 A3.5,3.5 0 1 0 12,8.5 A3.5,3.5 0 1 0 12,15.5 M19.4,15 A1.65,1.65 0 0 0 19.7,16.8 L19.8,16.9 A2,2 0 0 1 16.9,19.8 L16.8,19.7 A1.65,1.65 0 0 0 15,19.4 A1.65,1.65 0 0 0 14,20.9 L14,21 A2,2 0 0 1 10,21 L10,20.9 A1.65,1.65 0 0 0 9,19.4 A1.65,1.65 0 0 0 7.2,19.7 L7.1,19.8 A2,2 0 0 1 4.2,16.9 L4.3,16.8 A1.65,1.65 0 0 0 4.6,15 A1.65,1.65 0 0 0 3.1,14 L3,14 A2,2 0 0 1 3,10 L3.1,10 A1.65,1.65 0 0 0 4.6,9 A1.65,1.65 0 0 0 4.3,7.2 L4.2,7.1 A2,2 0 0 1 7.1,4.2 L7.2,4.3 A1.65,1.65 0 0 0 9,4.6 A1.65,1.65 0 0 0 10,3.1 L10,3 A2,2 0 0 1 14,3 L14,3.1 A1.65,1.65 0 0 0 15,4.6 A1.65,1.65 0 0 0 16.8,4.3 L16.9,4.2 A2,2 0 0 1 19.8,7.1 L19.7,7.2 A1.65,1.65 0 0 0 19.4,9 A1.65,1.65 0 0 0 20.9,10 L21,10 A2,2 0 0 1 21,14 L20.9,14 A1.65,1.65 0 0 0 19.4,15</Geometry>
        <Geometry x:Key="IconoActividad">M22,12 L18,12 L15,21 L9,3 L6,12 L2,12</Geometry>
        <Geometry x:Key="IconoBloqueo">M7,11 L17,11 L17,21 L7,21 Z M9,11 L9,7 A3,3 0 0 1 15,7 L15,11</Geometry>
        <Geometry x:Key="IconoRegistro">M14,2 L6,2 A2,2 0 0 0 4,4 L4,20 A2,2 0 0 0 6,22 L18,22 A2,2 0 0 0 20,20 L20,8 Z M14,2 L14,8 L20,8 M8,13 L16,13 M8,17 L16,17 M8,9 L10,9</Geometry>
        <Geometry x:Key="IconoRefrescar">M21,12 A9,9 0 0 1 6,18.7 L3,16 M3,16 L3,22 M3,16 L9,16 M3,12 A9,9 0 0 1 18,5.3 L21,8 M21,8 L21,2 M21,8 L15,8</Geometry>
        <Geometry x:Key="IconoEnviar">M22,2 L11,13 M22,2 L15,22 L11,13 L2,9 Z</Geometry>
        <Geometry x:Key="IconoMonitor">M3,4 L21,4 L21,16 L3,16 Z M8,20 L16,20 M12,16 L12,20</Geometry>
        <Geometry x:Key="IconoAlerta">M10.3,3.9 L1.8,18 A2,2 0 0 0 3.5,21 L20.5,21 A2,2 0 0 0 22.2,18 L13.7,3.9 A2,2 0 0 0 10.3,3.9 M12,9 L12,13 M12,17 L12.01,17</Geometry>

        <Style x:Key="EstiloIcono" TargetType="Path">
            <Setter Property="Width" Value="16" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Stretch" Value="Uniform" />
            <Setter Property="Stroke" Value="{StaticResource TextBrush}" />
            <Setter Property="StrokeThickness" Value="2" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="Fill" Value="Transparent" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="#252831" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Fondo"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Fondo" Property="Background" Value="#303440" />
                                <Setter TargetName="Fondo" Property="BorderBrush" Value="#4B5563" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Fondo" Property="Background" Value="#1F2937" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BotonIcono" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8" />
        </Style>

        <Style x:Key="BotonMenu" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="10,8" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="Padding" Value="9,6" />
            <Setter Property="Background" Value="{StaticResource InputBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="ListView">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="Background" Value="#1B1E26" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSubtle}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Fondo"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="7,7,0,0"
                                Padding="12,8">
                            <ContentPresenter ContentSource="Header" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Fondo" Property="Background" Value="{StaticResource PanelAltBrush}" />
                                <Setter TargetName="Fondo" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Fondo" Property="BorderBrush" Value="#4B5563" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>
