<!-- Descripcion: Interfaz principal del lanzador de scripts PowerShell. -->
<Window x:Class="LanzadorScripts.VentanaPrincipal"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:modelos="clr-namespace:LanzadorScripts.Modelos"
        xmlns:modelosVista="clr-namespace:LanzadorScripts.ModelosVista"
        mc:Ignorable="d"
        Title="Lanzador de Scripts PowerShell"
        Height="760"
        Width="1180"
        MinHeight="620"
        MinWidth="980"
        Background="{StaticResource SurfaceBrush}">
    <Window.Resources>
        <DataTemplate DataType="{x:Type modelos:InformacionScript}">
            <Border Padding="10"
                    Background="{StaticResource InputBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,0,1">
                <StackPanel>
                    <TextBlock Text="{Binding Nombre}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Text="{Binding TextoPermiso}"
                               FontSize="11"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="PlantillaCabeceraEjecucion" DataType="{x:Type modelosVista:ModeloEjecucionScript}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Script.Nombre}" />
                <TextBlock Text="  " />
                <TextBlock Text="{Binding TextoEstado}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="PlantillaContenidoEjecucion" DataType="{x:Type modelosVista:ModeloEjecucionScript}">
            <Grid Margin="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{StaticResource PanelAltBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="10"
                        Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding Script.Nombre}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding RutaLog}"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock FontSize="11" Foreground="{StaticResource MutedTextBrush}">
                                <Run Text="Estado: " />
                                <Run Text="{Binding TextoEstado}" />
                                <Run Text="  Codigo: " />
                                <Run Text="{Binding CodigoSalida}" />
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Button Content="Cancelar"
                                    Click="CancelarEjecucion_Click" />
                            <Button Content="Abrir log"
                                    Click="AbrirLog_Click" />
                            <Button Content="Cerrar"
                                    Click="CerrarEjecucion_Click" />
                        </StackPanel>
                    </Grid>
                </Border>

                <TextBox Grid.Row="1"
                         Text="{Binding TextoSalida, Mode=OneWay}"
                         FontFamily="Consolas"
                         FontSize="13"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextChanged="TextoSalida_TextChanged"
                         Background="#020617"
                         Foreground="#D1FAE5"
                         BorderBrush="{StaticResource BorderBrushSoft}"
                         Padding="10" />

                <Grid Grid.Row="2" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TextoEntrada, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="Entrada_KeyDown"
                             ToolTip="Texto que se enviara al script" />
                    <Button Grid.Column="1"
                            Content="Enviar"
                            Margin="8,0,0,0"
                            Click="EnviarEntrada_Click" />
                </Grid>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="390" />
            <ColumnDefinition Width="10" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="Lanzador de scripts"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock x:Name="TextoIdentidad"
                               Margin="0,4,0,4"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock x:Name="TextoOrigen"
                               Text="Origen configurado por administracion"
                               Margin="0,0,0,10"
                               Foreground="{StaticResource MutedTextBrush}" />
                </StackPanel>

                <Grid Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="70" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Paralelo"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource TextBrush}"
                               Margin="0,0,8,0" />
                    <TextBox x:Name="TextoMaximoParalelo"
                             Grid.Column="1"
                             Text="5" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal">
                        <Button Content="Guardar"
                                Click="GuardarConfiguracion_Click" />
                        <Button Content="Refrescar"
                                Click="RefrescarScripts_Click" />
                    </StackPanel>
                </Grid>

                <ListView x:Name="ListaScripts"
                          Grid.Row="2"
                          BorderBrush="{StaticResource BorderBrushSoft}"
                          BorderThickness="1"
                          SelectionMode="Single" />

                <Grid Grid.Row="3" Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TextoRecuentoScripts"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedTextBrush}" />
                    <Button Grid.Column="1"
                            Content="Ejecutar"
                            FontWeight="SemiBold"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#020617"
                            Click="EjecutarScriptSeleccionado_Click" />
                </Grid>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent" />

        <Border Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0"
                           Margin="12"
                           LastChildFill="False">
                    <TextBlock Text="Ejecuciones"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}"
                               DockPanel.Dock="Left" />
                    <TextBlock x:Name="TextoRecuentoEjecuciones"
                               DockPanel.Dock="Right"
                               Foreground="{StaticResource MutedTextBrush}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <TabControl x:Name="PestanasEjecucion"
                            Grid.Row="1"
                            Margin="8,0,8,8"
                            ItemTemplate="{StaticResource PlantillaCabeceraEjecucion}"
                            ContentTemplate="{StaticResource PlantillaContenidoEjecucion}" />
            </Grid>
        </Border>
    </Grid>
</Window>
